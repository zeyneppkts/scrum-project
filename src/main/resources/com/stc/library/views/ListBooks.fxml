<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Label?>

<VBox alignment="TOP_CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.stc.library.controller.ListBooksController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Registered Books">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <TableView fx:id="bookTable" prefHeight="450.0" prefWidth="760.0">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="160.0" />
            <TableColumn fx:id="authorColumn" text="Author" prefWidth="120.0" />
            <TableColumn fx:id="yearColumn" text="Year" prefWidth="80.0" />
            <TableColumn fx:id="editionColumn" text="Edition" prefWidth="80.0" />
            <TableColumn fx:id="publisherColumn" text="Publisher" prefWidth="120.0" />
            <TableColumn fx:id="copiesColumn" text="Copies" prefWidth="70.0" />
            <TableColumn fx:id="availableColumn" text="Available" prefWidth="70.0" />
            <TableColumn fx:id="borrowCountColumn" text="Borrowed" prefWidth="80.0" />
            <TableColumn fx:id="isbnColumn" text="ISBN" prefWidth="140.0" />
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="10.0">
        <Button text="Borrow Selected Book" onAction="#handleBorrowBook" prefWidth="180" />
        <Button text="Back to Add Book" onAction="#handleBackToAddBook" prefWidth="180" />
    </HBox>
</VBox>

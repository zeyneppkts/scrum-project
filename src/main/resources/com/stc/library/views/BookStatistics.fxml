<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.stc.library.controller.BookStatisticsController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Library Statistics Dashboard">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>


    <HBox spacing="20" alignment="CENTER">
        <BarChart fx:id="borrowChart" title="Top 5 Borrowed Books" prefWidth="400" prefHeight="400" animated="false">
            <xAxis>
                <CategoryAxis label="Book Title" />
            </xAxis>
            <yAxis>
                <NumberAxis label="Total Borrows" />
            </yAxis>
        </BarChart>

        <BarChart fx:id="ratingChart" title="Top 5 Rated Books" prefWidth="400" prefHeight="400" animated="false">
            <xAxis>
                <CategoryAxis label="Book Title" />
            </xAxis>
            <yAxis>
                <NumberAxis label="Average Rating (0-5)" autoRanging="false" lowerBound="0" upperBound="5" tickUnit="1"/>
            </yAxis>
        </BarChart>
    </HBox>
</VBox>